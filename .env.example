# copy to .env and replace placeholders

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/spendhist

# ── OCR (Hugging Face model id) ─────────────────────────────────────
MODEL_NAME_OCR=

# ── Parser (OpenAI-compatible API, same host as G0I_API_KEY) ───────
PARSER_MODEL=deepseek-v3
HF_TOKEN=

# ── Upload directories (relative to project root) ───────────────────
RECEIPTS_IMG_DIR=receipts_img
RECEIPTS_RAW_DIR=receipts_raw

# ── SQL sub-agent LLM (OpenAI-compatible id / name) ─────────────────
SQL_MODEL=

# ── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Agent LLMs (OpenAI-compatible API; see ChatOpenAI base_url in code)
G0I_API_KEY=
AGENTIC_MODEL=

# ── Currency tool — https://currencyfreaks.com ──────────────────────
CURRENCYFREAKS_API_KEY=

# ── Optional tuning (defaults are safe for dev) ─────────────────────
# CORS_ORIGINS=https://app.example.com,http://localhost:3000
# DB_POOL_SIZE=5
# DB_POOL_MAX_OVERFLOW=10
# DB_TOOL_MAX_LIMIT=200
# DB_TOOL_MAX_JSON_BYTES=256000
# DB_TOOL_STATEMENT_TIMEOUT_MS=8000
# OCR_DEVICE=auto
# MAX_UPLOAD_BYTES=15728640
# MAX_PDF_PAGES=30
# DEFAULT_RECEIPT_PAGE_SIZE=20
# MAX_RECEIPT_PAGE_SIZE=100
# SEARCH_RESULTS_CAP=50
# RATE_LIMIT_REGISTER_PER_MINUTE=10
# RATE_LIMIT_LOGIN_PER_MINUTE=20
# RATE_LIMIT_UPLOAD_PER_MINUTE=30
# RATE_LIMIT_CHAT_PER_MINUTE=60
